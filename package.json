{
  "name": "@uarlouski/testrail-mcp-server",
  "version": "1.11.0",
  "mcpName": "io.github.uarlouski/testrail-mcp-server",
  "description": "Model Context Protocol (MCP) server for TestRail integration, enabling LLMs to fetch test cases and metadata.",
  "main": "dist/index.js",
  "bin": {
    "testrail-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "rimraf dist && tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testrail",
    "server",
    "typescript",
    "llm",
    "ai",
    "testing",
    "automation"
  ],
  "author": "Uladzislau Arlouski",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uarlouski/testrail-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/uarlouski/testrail-mcp-server/issues"
  },
  "homepage": "https://github.com/uarlouski/testrail-mcp-server#readme",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "archiver": "^7.0.1",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "@jest/globals": "^29.7.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.1.2",
      "onFail": "error"
    }
  }
}